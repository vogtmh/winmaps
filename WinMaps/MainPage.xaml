<Page
    x:Class="WinMaps.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:local="using:WinMaps"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToFontWeightConverter x:Key="BoldConverter" />
        <local:BoolToActiveColorConverter x:Key="ActiveColorConverter" />
    </Page.Resources>

    <Grid>
        <!-- Map surface (Win2D GPU-accelerated) -->
        <canvas:CanvasControl x:Name="MapCanvas"
                ClearColor="#FFF2EFE9"
                Draw="MapCanvas_Draw"
                PointerPressed="MapCanvas_PointerPressed"
                PointerMoved="MapCanvas_PointerMoved"
                PointerReleased="MapCanvas_PointerReleased"
                PointerWheelChanged="MapCanvas_PointerWheelChanged"
                ManipulationMode="TranslateX,TranslateY,Scale"
                ManipulationDelta="MapCanvas_ManipulationDelta"
                SizeChanged="MapCanvas_SizeChanged" />

        <!-- Floating control buttons (bottom-right) -->
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,12,12">
            <Button x:Name="BtnZoomIn" Content="+" Width="44" Height="44"
                    FontSize="20" FontWeight="Bold" Margin="0,0,0,6"
                    Click="BtnZoomIn_Click"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" />
            <Button x:Name="BtnZoomOut" Content="−" Width="44" Height="44"
                    FontSize="20" FontWeight="Bold" Margin="0,0,0,6"
                    Click="BtnZoomOut_Click"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" />
            <Button x:Name="BtnGps" Width="44" Height="44"
                    FontSize="16"
                    Click="BtnGps_Click"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <TextBlock x:Name="GpsIcon" Text="◎" FontSize="20" />
            </Button>
        </StackPanel>

        <!-- Map Manager button (bottom-left) -->
        <Button x:Name="BtnMapManager" Width="44" Height="44"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="12,0,0,12"
                Click="BtnMapManager_Click"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <FontIcon Glyph="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
        </Button>

        <!-- Status bar (top) -->
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top"
              Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
              Opacity="0.85" Padding="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtStatus" Text="WinMaps"
                       FontSize="12" VerticalAlignment="Center" />
            <TextBlock x:Name="TxtZoom" Text="Z12"
                       Grid.Column="1" FontSize="12" VerticalAlignment="Center" />
        </Grid>

        <!-- Download/Import progress overlay -->
        <Grid x:Name="OverlayPanel" Visibility="Collapsed"
              Background="{ThemeResource SystemControlBackgroundAltMediumHighBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Padding="32" MaxWidth="400">
                <TextBlock x:Name="TxtOverlayTitle" Text="WinMaps"
                           FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,16" />
                <TextBlock x:Name="TxtOverlayStatus" Text="No map data found."
                           TextWrapping="Wrap" HorizontalAlignment="Center"
                           Margin="0,0,0,16" />
                <!-- Batch segment bar: shown only during multi-region downloads -->
                <StackPanel x:Name="BatchSegmentBar" Orientation="Horizontal"
                            HorizontalAlignment="Center" Visibility="Collapsed"
                            Margin="0,0,0,12" />
                <ProgressBar x:Name="ProgressOverlay" Minimum="0" Maximum="100"
                             Value="0" Margin="0,0,0,8" />
                <TextBlock x:Name="TxtOverlayDetail" Text=""
                           FontSize="11" Opacity="0.7"
                           HorizontalAlignment="Center" Margin="0,0,0,16" />
                <Button x:Name="BtnDownload" Content="Download Stuttgart Region"
                        HorizontalAlignment="Center"
                        Click="BtnDownload_Click"
                        Visibility="Collapsed" />
                <Button x:Name="BtnCancel" Content="Cancel"
                        HorizontalAlignment="Center" Margin="0,8,0,0"
                        Visibility="Collapsed"
                        Click="BtnCancel_Click" />
            </StackPanel>
        </Grid>

        <!-- Map Manager overlay -->
        <Grid x:Name="MapManagerPanel" Visibility="Collapsed"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

            <!-- My Maps view -->
            <Grid x:Name="MyMapsView" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Padding="8,12,16,12" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Background="Transparent" Margin="0,0,8,0"
                            Click="BtnCloseManager_Click">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                    </Button>
                    <TextBlock Grid.Column="1" Text="My Maps" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Downloaded maps list -->
                <ListView x:Name="LvMyMaps" Grid.Row="1" Padding="8"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,10" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                            Tapped="MapItem_Tapped" Tag="{Binding Id}">
                                    <TextBlock Text="{Binding Name}" FontSize="15"
                                               FontWeight="{Binding IsActive, Converter={StaticResource BoldConverter}}"
                                               Foreground="{Binding IsActive, Converter={StaticResource ActiveColorConverter}}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SubtitleText}" FontSize="11"
                                               Opacity="0.6" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Use" Margin="8,0,0,0"
                                        Tag="{Binding Id}"
                                        Click="BtnUseMap_Click"
                                        Visibility="{Binding UseVisibility}" />
                                <Button Grid.Column="2" Margin="8,0,0,0"
                                        Tag="{Binding Id}"
                                        Click="BtnDeleteMap_Click">
                                    <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty state / add button -->
                <StackPanel Grid.Row="2" Padding="16,8">
                    <TextBlock x:Name="TxtTotalSize" FontSize="12" Opacity="0.5"
                               HorizontalAlignment="Right" Margin="0,0,0,4" />
                    <TextBlock x:Name="TxtNoMaps" Text="No maps downloaded yet."
                               Opacity="0.6" HorizontalAlignment="Center"
                               Margin="0,0,0,8" Visibility="Collapsed" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="＋ Add Map"
                                HorizontalAlignment="Stretch"
                                Click="BtnAddMap_Click" />
                        <Button Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Click="BtnWorldMap_Click">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE909;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Map View" VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- World Map view -->
            <Grid x:Name="WorldMapView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Padding="8,12,16,12"
                      Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnWorldMapBack" Background="Transparent" Margin="0,0,8,0"
                            Click="BtnWorldMapBack_Click">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                    </Button>
                    <TextBlock x:Name="TxtWorldMapTitle" Text="World"
                               Grid.Column="1" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </Grid>

                <!-- Canvas for region polygons + loading indicator -->
                <Grid Grid.Row="1">
                    <canvas:CanvasControl x:Name="WorldMapCanvas"
                                          Draw="WorldMapCanvas_Draw"
                                          PointerPressed="WorldMapCanvas_PointerPressed" />
                    <TextBlock x:Name="TxtWorldMapLoading" Text="Loading map data…"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0.6" Visibility="Collapsed" />
                </Grid>
            </Grid>

            <!-- Browse view -->
            <Grid x:Name="BrowseView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header with breadcrumb + refresh -->
                <Grid Grid.Row="0" Padding="8,12,16,12"
                      Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnBrowseBack" Background="Transparent" Margin="0,0,8,0"
                            Click="BtnBrowseBack_Click">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                    </Button>
                    <TextBlock x:Name="TxtBrowseTitle" Text="Select Region"
                               Grid.Column="1" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="2" Background="Transparent"
                            Click="BtnRefreshCatalog_Click">
                        <FontIcon Glyph="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                    </Button>
                </Grid>

                <!-- Region list -->
                <ListView x:Name="LvBrowse" Grid.Row="1" Padding="8"
                          SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="LvBrowse_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Optional section header (e.g. "Near me") -->
                                <TextBlock Text="{Binding SectionHeader}"
                                           Visibility="{Binding SectionVisibility}"
                                           FontSize="13" Foreground="Gray"
                                           Margin="0,8,0,4" />
                                <!-- Region row -->
                                <Grid Padding="8,10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}"
                                              FontFamily="Segoe MDL2 Assets" FontSize="18"
                                              Margin="0,0,12,0" VerticalAlignment="Center"
                                              Opacity="0.7" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Visibility="{Binding SubtitleVisibility}"
                                                   FontSize="12" Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Download All button (only visible when viewing a parent with children) -->
                <Button x:Name="BtnDownloadAll" Grid.Row="2"
                        HorizontalAlignment="Stretch" Margin="16,8"
                        Click="BtnDownloadAll_Click" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="Download All" Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
        <!-- Theme selector overlay -->
        <Grid x:Name="ThemePanel" Visibility="Collapsed"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="8,12,16,12"
                  Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Background="Transparent" Margin="0,0,8,0"
                        Click="BtnCloseTheme_Click">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                </Button>
                <TextBlock Grid.Column="1" Text="Map Theme" FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Theme list -->
            <ListView x:Name="LvThemes" Grid.Row="1" Padding="8"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12,14" Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40"
                                    CornerRadius="6" Margin="0,0,12,0">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding PreviewColor}" />
                                </Border.Background>
                                <TextBlock Text="―" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding PreviewRoadColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding ActiveMarker}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Opacity="0.7" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>

        <!-- ====== Slide-up Menu (CoMaps-style bottom sheet) ====== -->
        <!-- Scrim: tap-to-dismiss translucent background -->
        <Rectangle x:Name="MenuScrim"
                   Fill="Black" Opacity="0" Visibility="Collapsed"
                   PointerPressed="MenuScrim_PointerPressed" />

        <!-- Bottom sheet -->
        <Grid x:Name="MenuPanel"
              VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
              Visibility="Collapsed">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="MenuTranslate" Y="400" />
            </Grid.RenderTransform>
            <Grid.Resources>
                <Storyboard x:Name="MenuSlideIn">
                    <DoubleAnimation Storyboard.TargetName="MenuTranslate"
                                     Storyboard.TargetProperty="Y"
                                     To="0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="MenuScrim"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0.4" Duration="0:0:0.25" />
                </Storyboard>
                <Storyboard x:Name="MenuSlideOut">
                    <DoubleAnimation Storyboard.TargetName="MenuTranslate"
                                     Storyboard.TargetProperty="Y"
                                     To="400" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseIn" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="MenuScrim"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.2" />
                </Storyboard>
            </Grid.Resources>

            <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                    CornerRadius="12,12,0,0"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel>
                    <!-- Drag handle -->
                    <Rectangle Width="36" Height="4" RadiusX="2" RadiusY="2"
                               HorizontalAlignment="Center" Margin="0,10,0,6"
                               Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                    <!-- Manage maps -->
                    <Button x:Name="BtnMenuManageMaps"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" Padding="20,16"
                            Click="BtnMenuManageMaps_Click">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE81E;" FontFamily="Segoe MDL2 Assets"
                                      FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Manage maps" FontSize="16"
                                       VerticalAlignment="Center" Margin="16,0,0,0" />
                        </StackPanel>
                    </Button>

                    <!-- Themes -->
                    <Button x:Name="BtnMenuThemes"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" Padding="20,16"
                            Click="BtnMenuThemes_Click">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE771;" FontFamily="Segoe MDL2 Assets"
                                      FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Themes" FontSize="16"
                                       VerticalAlignment="Center" Margin="16,0,0,0" />
                        </StackPanel>
                    </Button>

                    <!-- Preferences -->
                    <Button x:Name="BtnMenuPreferences"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" Padding="20,16"
                            Click="BtnMenuPreferences_Click">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                      FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Preferences" FontSize="16"
                                       VerticalAlignment="Center" Margin="16,0,0,0" />
                        </StackPanel>
                    </Button>

                    <!-- Safe-area spacer -->
                    <Rectangle Height="16" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ====== Preferences panel ====== -->
        <Grid x:Name="PreferencesPanel" Visibility="Collapsed"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="8,12,16,12"
                  Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Background="Transparent" Margin="0,0,8,0"
                        Click="BtnClosePreferences_Click">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                </Button>
                <TextBlock Grid.Column="1" Text="Preferences" FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="20,16">

                    <!-- Tracking -->
                    <TextBlock Text="TRACKING" FontSize="11" FontWeight="SemiBold"
                               Opacity="0.5" Margin="0,0,0,12" CharacterSpacing="100" />

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Keep display on" FontSize="15" />
                            <TextBlock Text="Prevents the screen from turning off while following your position"
                                       FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="TglKeepDisplayOn" Grid.Column="1"
                                      IsOn="True" MinWidth="0"
                                      VerticalAlignment="Center"
                                      Toggled="TglKeepDisplayOn_Toggled" />
                    </Grid>

                    <!-- Divider -->
                    <Rectangle Height="1" Margin="0,12,0,16"
                               Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" />

                    <!-- Temp files -->
                    <TextBlock Text="TEMPORARY FILES" FontSize="11" FontWeight="SemiBold"
                               Opacity="0.5" Margin="0,0,0,12" CharacterSpacing="100" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Delete maps after import" FontSize="15" />
                            <TextBlock Text="Removes the downloaded Geofabrik PBF file once it has been imported"
                                       FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="TglDeletePbfAfterImport" Grid.Column="1"
                                      IsOn="False" MinWidth="0"
                                      VerticalAlignment="Center"
                                      Toggled="TglDeletePbfAfterImport_Toggled" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Downloaded PBF files" FontSize="15" />
                            <TextBlock x:Name="TxtPbfSize" Text="Calculating…"
                                       FontSize="12" Opacity="0.6" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Clear"
                                VerticalAlignment="Center"
                                Click="BtnClearPbf_Click" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Partial downloads" FontSize="15" />
                            <TextBlock x:Name="TxtPartialSize" Text="Calculating…"
                                       FontSize="12" Opacity="0.6" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Clear"
                                VerticalAlignment="Center"
                                Click="BtnClearPartial_Click" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Geofabrik catalog cache" FontSize="15" />
                            <TextBlock x:Name="TxtCacheSize" Text="Calculating…"
                                       FontSize="12" Opacity="0.6" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Clear"
                                VerticalAlignment="Center"
                                Click="BtnClearCache_Click" />
                    </Grid>

                    <!-- Divider -->
                    <Rectangle Height="1" Margin="0,8,0,16"
                               Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" />

                    <!-- About -->
                    <TextBlock Text="ABOUT" FontSize="11" FontWeight="SemiBold"
                               Opacity="0.5" Margin="0,0,0,12" CharacterSpacing="100" />

                    <TextBlock x:Name="TxtAppVersion" Text="WinMaps"
                               FontSize="15" Opacity="0.8" />
                    <TextBlock x:Name="TxtBuildDate" Text=""
                               FontSize="12" Opacity="0.5" Margin="0,2,0,0" />
                    <TextBlock Text="Developed by Mavodev"
                               FontSize="12" Opacity="0.6" Margin="0,6,0,0" />
                    <TextBlock Text="Map data © OpenStreetMap contributors"
                               FontSize="12" Opacity="0.5" Margin="0,4,0,0"
                               TextWrapping="Wrap" />

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
